rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /links/{linkId} {
      allow create: if request.auth != null && request.resource.data.owner_uid == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.owner_uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.owner_uid == request.auth.uid
        && request.resource.data.owner_uid == request.auth.uid;
    }
  }
}
